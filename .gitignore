# Local CDN fallback (NOT committed; kept on disk in case jsdelivr's +esm /
# redirect endpoints loop again and hang init). To recover, repoint the CDN
# imports at these local copies:
#   index.html        dockview.css link  -> lib/dockview-core/dockview.css
#   index.html        importmap "yaml"   -> ./lib/yaml/browser/index.js
#   ui/sessions-panes.js  dockview +esm  -> ../lib/dockview-core/main.esm.mjs
#   loading/frame-worker.js + slp-import-worker.js  h5wasm +esm -> ../lib/h5wasm/hdf5_hl.js
# Re-fetch instructions live in each dir's PROVENANCE.txt. (lib/h5wasm and
# lib/sleap-io are committed; only these two vendored fallbacks are ignored.)
lib/dockview-core/
lib/yaml/
